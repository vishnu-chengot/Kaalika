---
---
<nav id="navbar" class="fixed top-0 left-0 w-full z-50 transition-all duration-500 py-6 px-8 md:px-16 flex justify-between items-center bg-transparent">
  <div class="flex flex-col">
    <span class="text-2xl md:text-3xl font-serif tracking-widest uppercase text-white">Kāalika</span>
    <span class="text-[10px] md:text-xs tracking-[0.3em] uppercase text-accent-gold ml-1">by Clothing</span>
  </div>

  <div class="hidden md:flex gap-12 text-xs uppercase tracking-widest font-light text-white/80">
    <a href="#collection" class="hover:text-white transition-colors">Collection</a>
    <a href="#story" class="hover:text-white transition-colors">Our Story</a>
    <a href="#about" class="hover:text-white transition-colors">About</a>
    <a href="#contact" class="hover:text-white transition-colors">Contact</a>
  </div>

  <button class="md:hidden text-white">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"></line><line x1="4" x2="20" y1="6" y2="6"></line><line x1="4" x2="20" y1="18" y2="18"></line></svg>
  </button>
</nav>

<script>
  const nav = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    if (window.scrollY > 50) {
      nav?.classList.remove('py-6', 'bg-transparent');
      nav?.classList.add('py-4', 'bg-black/80', 'backdrop-blur-md', 'border-b', 'border-white/10');
    } else {
      nav?.classList.add('py-6', 'bg-transparent');
      nav?.classList.remove('py-4', 'bg-black/80', 'backdrop-blur-md', 'border-b', 'border-white/10');
    }
  });
</script>

<style>
  .text-accent-gold {
    color: #d4a853;
  }
</style>
