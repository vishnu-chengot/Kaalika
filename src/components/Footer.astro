---
---
<footer id="contact" class="py-32 px-8 md:px-24 bg-black border-t border-white/5">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-24">
      <div>
        <h2 class="text-4xl md:text-6xl font-serif text-white mb-12">Connect with <span class="italic text-accent-gold">Kāalika</span></h2>
        <form class="space-y-8">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
            <div class="space-y-2">
              <label class="text-[10px] uppercase tracking-[0.3em] text-white/40">Full Name</label>
              <input type="text" class="w-full bg-transparent border-b border-white/10 py-4 text-white focus:border-accent-gold outline-none transition-colors" placeholder="Enter your name" />
            </div>
            <div class="space-y-2">
              <label class="text-[10px] uppercase tracking-[0.3em] text-white/40">Email Address</label>
              <input type="email" class="w-full bg-transparent border-b border-white/10 py-4 text-white focus:border-accent-gold outline-none transition-colors" placeholder="email@example.com" />
            </div>
          </div>
          <div class="space-y-2">
            <label class="text-[10px] uppercase tracking-[0.3em] text-white/40">Your Inquiry</label>
            <textarea rows="4" class="w-full bg-transparent border-b border-white/10 py-4 text-white focus:border-accent-gold outline-none transition-colors resize-none" placeholder="How can we assist you?"></textarea>
          </div>
          <button type="submit" class="group flex items-center gap-4 text-white text-xs uppercase tracking-[0.5em] font-light hover:text-accent-gold transition-colors">
            Send Message
            <span class="w-12 h-[1px] bg-white/20 group-hover:bg-accent-gold group-hover:w-20 transition-all duration-500"></span>
          </button>
        </form>

        <div class="mt-20">
          <a href="https://wa.me/910000000000" target="_blank" class="inline-flex items-center gap-4 px-8 py-5 bg-[#25D366] text-white rounded-full hover:bg-[#20bd5c] transition-all transform hover:scale-105 shadow-lg shadow-green-500/20">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.414 0 .004 5.41.001 12.045a11.815 11.815 0 001.591 5.976L0 24l6.117-1.604a11.803 11.803 0 005.926 1.568h.005c6.637 0 12.048-5.411 12.052-12.045a11.8 11.8 0 00-3.536-8.509"/></svg>
            Inquiry on WhatsApp
          </a>
        </div>
      </div>

      <div class="flex flex-col justify-between">
        <div class="mb-24">
          <span class="text-4xl md:text-6xl font-serif tracking-widest uppercase text-white block">Kāalika</span>
          <span class="text-xs tracking-[0.5em] uppercase text-accent-gold ml-1">Redefining Black Sarees</span>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-3 gap-12 mb-24">
          <div class="space-y-6">
            <h4 class="text-[10px] uppercase tracking-[0.4em] text-white/30">Connect</h4>
            <ul class="space-y-4 text-xs font-light tracking-widest text-white/60">
              <li><a href="#" class="hover:text-accent-gold transition-colors">Instagram</a></li>
              <li><a href="#" class="hover:text-accent-gold transition-colors">Facebook</a></li>
              <li><a href="#" class="hover:text-accent-gold transition-colors">Pinterest</a></li>
            </ul>
          </div>
          <div class="space-y-6">
            <h4 class="text-[10px] uppercase tracking-[0.4em] text-white/30">Company</h4>
            <ul class="space-y-4 text-xs font-light tracking-widest text-white/60">
              <li><a href="#" class="hover:text-accent-gold transition-colors">Journal</a></li>
              <li><a href="#" class="hover:text-accent-gold transition-colors">Shipping</a></li>
              <li><a href="#" class="hover:text-accent-gold transition-colors">Policies</a></li>
            </ul>
          </div>
          <div class="space-y-6 col-span-2 lg:col-span-1">
            <h4 class="text-[10px] uppercase tracking-[0.4em] text-white/30">Studio</h4>
            <p class="text-xs font-light tracking-widest text-white/60 leading-relaxed">
              12/A, Heritage Mile,<br />
              Kochi, Kerala, India - 682001
            </p>
          </div>
        </div>

        <div class="pt-12 border-t border-white/5 flex flex-col md:flex-row justify-between gap-8 text-[9px] uppercase tracking-[.4em] text-white/20">
          <p>© 2026 Kāalika by Clothing. All Rights Reserved.</p>
          <div class="flex gap-8">
            <a href="#">Privacy Policy</a>
            <a href="#">Terms of Service</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<style>
  .text-accent-gold {
    color: #d4a853;
  }
</style>
