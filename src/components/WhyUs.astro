---
const features = [
  {
    title: "Premium Fabric",
    description: "Sourced from the finest silk weavers, our sarees offer an unmatched tactile experience.",
    icon: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"
  },
  {
    title: "Handcrafted Designs",
    description: "Every motif is painstakingly hand-woven by master artisans keeping the craft alive.",
    icon: "M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"
  },
  {
    title: "Kerala Tradition",
    description: "Rooted in the rich cultural heritage of Kerala, reimagined for the modern woman.",
    icon: "M20.38 3.46L16 2a4 4 0 01-8 0L3.62 3.46a2 2 0 00-1.62 1.97v13.14a2 2 0 001.62 1.97L8 22a4 4 0 008 0l4.38-1.46a2 2 0 001.62-1.97V5.43a2 2 0 00-1.62-1.97z"
  },
  {
    title: "Timeless Elegance",
    description: "Black isn't a trend; it's a legacy. Our pieces are designed to be heirlooms.",
    icon: "M12 12a5 5 0 100-10 5 5 0 000 10z M12 14c-6.1 0-11 2.9-11 6.5V22h22v-1.5c0-3.6-4.9-6.5-11-6.5z"
  }
];
---

<section id="why-us" class="py-32 px-8 md:px-24 bg-black overflow-hidden">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
      {features.map((feature, index) => (
        <div class="feature-card opacity-0 translate-y-10">
          <div class="w-12 h-12 mb-8 text-accent-gold">
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
              <path d={feature.icon}></path>
            </svg>
          </div>
          <h3 class="text-xl font-serif mb-4 text-white">{feature.title}</h3>
          <p class="text-sm font-light text-white/50 leading-relaxed">
            {feature.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<script>
  import { gsap } from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';
  gsap.registerPlugin(ScrollTrigger);

  gsap.to('.feature-card', {
    opacity: 1,
    y: 0,
    duration: 0.8,
    stagger: 0.2,
    ease: 'power3.out',
    scrollTrigger: {
      trigger: '#why-us',
      start: 'top 80%',
    }
  });
</script>

<style>
  .text-accent-gold {
    color: #d4a853;
  }
</style>
